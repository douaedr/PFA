            "format": "time"
          },
          "slotEndTime": {
            "type": "string",
            "format": "time"
          },
          "slotDurationMinutes": {
            "type": "integer",
            "format": "int32"
          },
          "workDays": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DayOfWeek"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateSlotDto": {
        "type": "object",
